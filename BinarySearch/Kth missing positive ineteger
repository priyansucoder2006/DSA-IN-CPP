class Solution {
public:
    int findKthPositive(vector<int>& arr, int k) {
    // Your code here
	int missingnumber=k;
	for(int i=0;i<arr.size();i++){
		if(arr[i]>missingnumber){
			return missingnumber;
		}
		else{
			missingnumber++;
		}
	}
	return missingnumber;	
}    
};
//optimize solution
int findKthPositive(vector<int>& arr, int k) {
    // Your code here
	int start=0;
	int end=arr.size()-1;
	int ans=arr.size();
	while(start<=end){
		int mid=start+(end-start)/2;
		if(arr[mid]-(mid+1)<k){
		start=mid+1;
		}
		else{
			ans=mid;
			end=mid-1;
		}
	}
	return ans+k;	
}

