int countZeroes(vector<int>& arr) {
    // Your code here
    int start=0;
    int end=arr.size()-1;
    int count=0;
    int index;
    int n=arr.size();
    if(arr[end]==1){
        return 0;
    }
    while(start<=end){
        int mid=end+(start-end)/2;
        if(arr[mid]==1){
            start=mid+1;
        }
        else if(arr[mid]==0){
            index=mid;
            end=mid-1;    
        }
      //  return n-index;
    }
    return n-index;
}
