int searchInsert(vector<int>& nums, int target) {
    // Your code here.
	int min=0;
	int index=nums.size();
		int max=nums.size()-1;
		while(min<=max){
		int mid=(min+max)/2;
		if(target==nums[mid]){
			return mid;
		}
		else if(target>nums[mid]){
			min=mid+1;
		}
		else{
			index=mid;
			max=mid-1;
		}
		}
		return index;
    
};
	
