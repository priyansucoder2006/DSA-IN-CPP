int maxDiff(vector<int> &arr) {
    // Your code here
    int n=arr.size();
    vector<int>prefixMax(n);
    prefixMax[n-1]=arr[n-1];
    for(int i=n-2;i>=0;i--){
        prefixMax[i]=max(prefixMax[i+1],arr[i]);
    }
    int ans=-1;
    for(int i=0;i<n-1;i++){
        if(prefixMax[i+1]>arr[i]){
        ans=max(ans,prefixMax[i+1]-arr[i]);
        }
    }
return ans;
    
}
