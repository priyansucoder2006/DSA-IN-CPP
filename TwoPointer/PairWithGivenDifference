int pairWithGivenDifference(vector<int>& arr, int diff) {
    // Your code here
    sort(arr.begin(),arr.end());
    int start=0;
    int end=0;
    while(start<=end&&end<arr.size()){
    if(arr[end]-arr[start]==diff){
        return 1;
    }
    else if(arr[end]-arr[start]<diff){
        end++;
    }
    else {
        start++;
    }
    } 
    return 0;
}
