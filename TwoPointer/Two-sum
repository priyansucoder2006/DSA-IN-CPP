class Solution {
public:
    vector<int> twoSum(vector<int>& arr, int target) {
        //code here
		vector<int>ans;
		int start=0;
		int end=arr.size()-1;
		while(start<end){
			if(arr[start]+arr[end]==target){
				ans.push_back(start+1);
				ans.push_back(end+1);
				break;
				
			}
			else if(arr[start]+arr[end]>target){
				end--;
			}
			else{
				start++;
			}
		}
		return ans;
    }
};
