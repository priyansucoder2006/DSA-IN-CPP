void rotate(vector<vector<int>>& matrix) {
    int row=matrix.size();
    int column=matrix[0].size();
    for(int i=0;i<row;i++){
        for(int j=0;j<column;j++){
      if(i!=j&&i<j){
        swap(matrix[i][j],matrix[j][i]);
      }
    }
    }
    int rowstart=0;
    int rowend=row-1;
    while(rowstart<rowend){
        for(int i=0;i<row;i++){
        swap(matrix[i][rowstart],matrix[i][rowend]);
        }
        rowstart++;
        rowend--;
    }   
}
