int rowWithMaxSum(vector<vector<int>>& mat) {
    // Your code here
    if(mat.size()==0||mat[0].size()==0){
        return -1;
    }
    int index;
    int ans=INT_MIN;
    for(int i=0;i<mat.size();i++){
        int sum=0;
        for(int j=0;j<mat[0].size();j++){
            sum+=mat[i][j];
        }
      if(sum>ans){
        ans=sum;
        index=i;
      }
    }
    return index;
}
